# ENIAK environment template — copy to .env and fill in.
# .env is gitignored; never commit secrets.

# === LLM (OpenAI-compatible endpoint, e.g. Aliyun DashScope coding, Moonshot Kimi, OpenAI) ===
LLM_API_KEY=
LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
ENIAK_DEFAULT_MODEL=qwen3.5-plus

# Optional fallback creds
KIMI_CODING_API_KEY=
KIMI_CODING_BASE_URL=https://api.kimi.com/coding/v1
DASHSCOPE_API_KEY=

# === Storage ===
# Local dev: SQLite (aiosqlite). Production: Supabase Postgres + pgvector.
# Production: Supabase Postgres via PgBouncer
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<pwd>@aws-1-<region>.pooler.supabase.com:6543/postgres
# DATABASE_URL_DIRECT=postgresql+psycopg://postgres.<ref>:<pwd>@aws-1-<region>.pooler.supabase.com:5432/postgres
# Local dev fallback:
DATABASE_URL=sqlite+aiosqlite:///./data/eniak.sqlite3
DATABASE_URL_DIRECT=

# === App config ===
# Comma-separated bearer tokens for POST /runs (write endpoints).
# Empty in production = 503 on writes (safe-by-default).
ENIAK_API_KEYS=
# Rate limit per client IP for POST /runs
ENIAK_RUNS_RATE_LIMIT=5/minute

ENIAK_ENV=development
ENIAK_STORAGE_DIR=./storage
ENIAK_CORS_ORIGINS=https://www.eniak.org,https://eniak.org,http://localhost:3000

# === Supabase (when promoting from SQLite) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_ACCESS_TOKEN=

# === Cloudflare (Pages + DNS on eniak.org) ===
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID_ENIAK_ORG=

# === Railway (backend host) ===
RAILWAY_ACCOUNT_TOKEN=
RAILWAY_PROJECT_TOKEN=

# === Search providers (Phase 3) ===
SEMANTIC_SCHOLAR_API_KEY=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# === Feishu / Lark publishing (Phase 5) ===
LARK_APP_ID=
LARK_APP_SECRET=
